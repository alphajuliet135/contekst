# !! REQUIRED — must be a stable, explicitly set value !!
# DO NOT leave empty. NextAuth v5 generates a random secret if unset,
# which invalidates ALL sessions on every container restart.
# Generate one: openssl rand -base64 32
AUTH_SECRET=""

# URL where the app is publicly served (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# SQLite database path
DATABASE_URL="file:./data/contekst.db"
