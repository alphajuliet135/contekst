# !! REQUIRED — must be a stable, explicitly set value !!
# DO NOT leave empty. NextAuth v5 generates a random secret if unset,
# which invalidates ALL sessions on every container restart.
# Generate one: openssl rand -base64 32
AUTH_SECRET=""

# URL where the app is publicly served (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# SQLite database path
DATABASE_URL="file:./data/contekst.db"

# ── Push notifications (optional) ───────────────────────────────────────────
# Generate VAPID keys once with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ prefix makes the public key available to the browser.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Random secret to protect the /api/push/notify dispatch endpoint.
# Generate one: openssl rand -base64 32
# Call it from a cron job:
#   0 8 * * * curl -s -X POST http://localhost:3000/api/push/notify \
#     -H "Authorization: Bearer $NOTIFY_SECRET"
NOTIFY_SECRET=""
